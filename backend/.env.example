# Which AI provider to use: "gemini" | "openai" | "claude"
AI_PROVIDER=gemini

# Provide the key for whichever provider you set above
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Model names (defaults are sane, override if you like)
GEMINI_MODEL=gemini-1.5-flash
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Server
PORT=4000

# CORS - your deployed frontend URL (comma separated for multiple)
CORS_ORIGIN=http://localhost:3000

# How many CSV rows to send to the AI per request
BATCH_SIZE=25

# Max retries per failed batch
MAX_BATCH_RETRIES=2
